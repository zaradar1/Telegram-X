<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allows http:// URLs (e.g. a local dev server or LAN IP) in addition to https://. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
